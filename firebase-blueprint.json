{
  "entities": {
    "Patient": {
      "title": "Patient",
      "description": "Registered patient records",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nationalId": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "gender": { "type": "string", "enum": ["female", "male"] },
        "age": { "type": "number" },
        "birthDate": { "type": "string" },
        "password": { "type": "string" },
        "registeredAt": { "type": "string" },
        "hn": { "type": "string" }
      },
      "required": ["id", "nationalId", "name", "phone", "gender", "age", "password", "registeredAt"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Patient checkup appointment booking details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "basicProgramName": { "type": "string" },
        "basicProgramPrice": { "type": "number" },
        "selectedBasicTests": { "type": "array" },
        "specialTests": { "type": "array" },
        "totalCost": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "completed", "cancelled", "pending_results"] },
        "patientType": { "type": "string", "enum": ["walk-in", "agency"] },
        "agencyName": { "type": "string" },
        "medicalCoverage": { "type": "string" },
        "confirmedServiceDate": { "type": "string" }
      },
      "required": ["id", "patientId", "date", "time", "basicProgramName", "basicProgramPrice", "specialTests", "totalCost", "status"]
    },
    "LM6Assessment": {
      "title": "LM6Assessment",
      "description": "Lifestyle Medicine 6-Pillar self-assessment scores and responses",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "date": { "type": "string" },
        "scores": { "type": "object" },
        "answers": { "type": "object" },
        "recommendations": { "type": "array" }
      },
      "required": ["id", "patientId", "date", "scores", "answers", "recommendations"]
    },
    "LabResult": {
      "title": "LabResult",
      "description": "Detailed laboratory and clinical examination results",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "appointmentId": { "type": "string" },
        "examDate": { "type": "string" },
        "doctorName": { "type": "string" },
        "doctorLicense": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed"] },
        "physical": { "type": "object" },
        "chestXray": { "type": "object" },
        "parameters": { "type": "object" },
        "attachedFiles": { "type": "array" },
        "summary": { "type": "string" },
        "recommendations": { "type": "array" }
      },
      "required": ["id", "patientId", "appointmentId", "examDate", "doctorName", "status", "physical", "chestXray", "parameters", "attachedFiles", "summary", "recommendations"]
    }
  },
  "firestore": {
    "/patients/{patientId}": {
      "schema": "Patient",
      "description": "Patients database"
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Appointments database"
    },
    "/assessments/{assessmentId}": {
      "schema": "LM6Assessment",
      "description": "Lifestyle Medicine self-assessments"
    },
    "/results/{resultId}": {
      "schema": "LabResult",
      "description": "Lab and checkup examination reports"
    }
  }
}
